# hc-hue plugin configuration
# Copy to config/config.toml and fill in your values.

[homecore]
broker_host = "127.0.0.1"
broker_port = 1883
plugin_id = "plugin.hue"
password = "change_me"

[hue]
# Enable bridge discovery hooks (currently scaffolded).
discovery_enabled = true

# Allow cloud fallback via N-UPnP endpoint (https://discovery.meethue.com).
discovery_cloud_fallback = true

# Discovery HTTP timeout in seconds.
discovery_timeout_secs = 5

# Subscribe to Hue v2 eventstream and trigger incremental refreshes.
eventstream_enabled = true

# Delay before reconnect attempt when eventstream disconnects.
eventstream_reconnect_secs = 3

# Periodic refresh cadence for bridge summaries.
resync_interval_secs = 60

# Plugin heartbeat/status publish cadence.
heartbeat_secs = 30

[hue.display]
# Temperature display unit in published state: "c" or "f".
temperature_unit = "c"
# Illuminance display value in published state: "lux" or "raw".
illuminance_display = "lux"

[[bridges]]
name = "main"
bridge_id = "001788fffe123456" # replace with your bridge ID
host = "192.168.1.55"          # replace with your bridge IP/host
app_key = "YOUR_HUE_APP_KEY"   # optional for read-only discovery; required for control/eventstream
verify_tls = true
allow_self_signed = true
